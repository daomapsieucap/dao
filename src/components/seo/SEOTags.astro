---
import { SEO } from "astro-seo";
import { SITE_URL } from "@/data/config";
import type { HeadTags } from "@/utils/types/HeadTags";
import newsreaderNormalLatin from "@fontsource-variable/newsreader/files/newsreader-latin-opsz-normal.woff2?url";
import newsreaderItalicLatin from "@fontsource-variable/newsreader/files/newsreader-latin-opsz-italic.woff2?url";
import newsreaderVietnamese from "@fontsource-variable/newsreader/files/newsreader-vietnamese-opsz-normal.woff2?url";
import jetbrainsMonoVietnamese from "@fontsource-variable/jetbrains-mono/files/jetbrains-mono-vietnamese-wght-normal.woff2?url";
import mainCssHref from "@/styles/main.css?url";
import jetbrainsMonoCssHref from "@fontsource-variable/jetbrains-mono?url";
import newsreaderOpszCssHref from "@fontsource-variable/newsreader/opsz.css?url";
import newsreaderOpszItalicCssHref from "@fontsource-variable/newsreader/opsz-italic.css?url";

type Props = HeadTags;

const { title, description, noindex, og } = Astro.props;

const DEFAULT_TITLE_PAGE = "dao chau · backend";
const DEFAULT_DESCRIPTION_PAGE =
  "writes the half of the web you never see. behind the curtain, keeping things running.";

const canonicalURL = new URL(Astro.url.pathname, SITE_URL).href;

const openGraph = {
  title: title || og?.title || DEFAULT_TITLE_PAGE,
  type: og?.type || "website",
  image: new URL(og?.image || "/opengraph-image.jpg", SITE_URL).href,
  alt: og?.alt || "dao chau's website",
  url: canonicalURL,
  description: og?.description || DEFAULT_DESCRIPTION_PAGE,
};

// Loaded via media="print" swap below so none of them block first paint.
const stylesheets = [
  mainCssHref,
  jetbrainsMonoCssHref,
  newsreaderOpszCssHref,
  newsreaderOpszItalicCssHref,
];
---

<head>
  <!-- Preload the font subsets behind the hero heading and the intro
       paragraph (#desc) so they're in the cache before layout/paint,
       instead of arriving late. -->
  <link rel="preload" as="font" type="font/woff2" href={newsreaderNormalLatin} crossorigin />
  <link rel="preload" as="font" type="font/woff2" href={newsreaderItalicLatin} crossorigin />
  <link rel="preload" as="font" type="font/woff2" href={newsreaderVietnamese} crossorigin />
  <link rel="preload" as="font" type="font/woff2" href={jetbrainsMonoVietnamese} crossorigin />
  <!-- Load every stylesheet (site styles + the three Fontsource font-face
       bundles) without blocking first paint: the media="print" swap trick
       fetches each at normal priority but only applies it once ready,
       instead of holding up rendering like a plain rel="stylesheet" link
       would. -->
  {stylesheets.map((href) => (
    <>
      <link rel="preload" href={href} as="style" />
      <link rel="stylesheet" href={href} media="print" onload="this.media='all'" />
      <noscript><link rel="stylesheet" href={href} /></noscript>
    </>
  ))}
  <SEO
    charset="UTF-8"
    title={title || DEFAULT_TITLE_PAGE}
    description={description || DEFAULT_DESCRIPTION_PAGE}
    noindex={noindex || false}
    openGraph={{
      basic: {
        title: openGraph.title,
        type: openGraph.type,
        image: openGraph.image,
        url: openGraph.url,
      },
      image: {
        alt: openGraph.alt,
      },
    }}
    twitter={{
      creator: "@daomapsieucap",
    }}
    extend={{
      link: [
        { rel: "icon", href: "/favicon.svg" },
        { rel: "sitemap", href: "/sitemap-index.xml" },
      ],
      meta: [
        { name: "viewport", content: "width=device-width, initial-scale=1" },
        { name: "generator", content: Astro.generator },
        { name: "twitter:image", content: openGraph.image },
        { name: "twitter:card", content: "summary_large_image" },
        { name: "twitter:title", content: openGraph.title },
        { name: "twitter:description", content: openGraph.description },
        { name: "twitter:site", content: "@daomapsieucap" },
      ],
    }}
  />
  <!-- Google tag (gtag.js) -->
  <script is:inline type="text/partytown" async src="https://www.googletagmanager.com/gtag/js?id=G-SDQ2PWY76X"></script>
  <script is:inline type="text/partytown">
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-SDQ2PWY76X');
  </script>
</head>
