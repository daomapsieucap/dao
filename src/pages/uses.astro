---
import Layout from "@/layouts/Layout.astro";
import LogoMark from "@/components/LogoMark.astro";
import RailFoot from "@/components/RailFoot.astro";
---

<Layout
        title="dao chau · uses"
        description="the tools behind the curtain. pinned, not locked"
>
    <main class="shell" data-screen-label="uses">

        <!-- identity rail -->
        <aside class="rail">
            <LogoMark />

            <div class="id-block">
                <h1 class="id-name"><a href="/"><span class="w">dao</span><span class="w">chau</span></a></h1>
                <p class="id-role">uses · the dotfiles</p>
            </div>

            <div class="rail-divider"></div>

            <nav aria-label="Sections">
                <ul class="nav">
                    <li><a href="/"><span class="n n-home" aria-hidden="true">cd</span><span class="t">~ home</span></a></li>
                    <li><a href="#bin"><span class="n" aria-hidden="true">01</span><span class="t">bin</span></a></li>
                    <li><a href="#hardware"><span class="n" aria-hidden="true">02</span><span class="t">hardware</span></a></li>
                    <li><a href="#env"><span class="n" aria-hidden="true">03</span><span class="t">env</span></a></li>
                </ul>
            </nav>

            <RailFoot />
        </aside>

        <!-- content column -->
        <div class="content">

            <p class="prompt"><b>dao@chau</b>:~$ <span class="cmd" aria-hidden="true">dao --uses</span><span class="cur"
                                                                                          aria-hidden="true"></span></p>

            <h2 class="hero">dotfiles, <em class="ln">the personal runtime.</em></h2>
            <p class="hero-sub">everything I actually reach for in a day, written down.</p>

            <!-- BIN -->
            <section id="bin" aria-labelledby="s-bin">
                <h3 class="sec" id="s-bin">
                    <span class="dot"></span>
                    <span class="lab"><span class="php" aria-hidden="true">&lt;?</span>BIN</span>
                    <span class="line"></span>
                    <span class="num">01</span>
                </h3>
                <p class="sec-note">the current stack. pinned, not locked.</p>
                <dl class="kv">
                    <dt>$ ide</dt>
                    <dd>PhpStorm. <em>knows what clients mean by "small change".</em></dd>
                    <dt>$ notes</dt>
                    <dd>Obsidian. <em>write it down, forget it safely.</em></dd>
                    <dt>$ browser</dt>
                    <dd>Brave. <em>switched once. no rollback.</em></dd>
                    <dt>$ ssh</dt>
                    <dd>Xermius.</dd>
                    <dt>$ shell</dt>
                    <dd>PowerShell.</dd>
                    <dt>$ ai</dt>
                    <dd>Claude.</dd>
                </dl>
            </section>

            <!-- HARDWARE -->
            <section id="hardware" aria-labelledby="s-hardware">
                <h3 class="sec" id="s-hardware">
                    <span class="dot"></span>
                    <span class="lab"><span class="php" aria-hidden="true">&lt;?</span>HARDWARE</span>
                    <span class="line"></span>
                    <span class="num">02</span>
                </h3>
                <p class="sec-note">the hardware half. runs until it dies.</p>
                <dl class="kv">
                    <dt>$ laptop</dt>
                    <dd>Lenovo ThinkPad T14. <em>the company's, technically.</em></dd>
                    <dt>$ pc</dt>
                    <dd>Dell XPS 8700. <em>still running.</em></dd>
                    <dt>$ display</dt>
                    <dd>Dell U2417H.</dd>
                    <dt>$ keyboard</dt>
                    <dd>Logitech K120. <em>simple, but it works.</em></dd>
                    <dt>$ mouse</dt>
                    <dd>Logitech MX Anywhere 3, with a Hyperwork Silentium S01 on quiet duty.</dd>
                    <dt>$ phone</dt>
                    <dd>Samsung S24.</dd>
                    <dt>$ tablet</dt>
                    <dd>Samsung Tab A9. <em>runs Netflix. tests breakpoints.</em></dd>
                    <dt>$ ereader</dt>
                    <dd>Kindle Paperwhite 4. <em>where the reading actually happens.</em></dd>
                    <dt>$ headphone</dt>
                    <dd>Sony WH-1000XM4. <em>noise cancelling on, world off.</em></dd>
                    <dt>$ earphone</dt>
                    <dd>Samsung Galaxy Buds 3 FE.</dd>
                </dl>
            </section>

            <!-- ENV -->
            <section id="env" aria-labelledby="s-env">
                <h3 class="sec" id="s-env">
                    <span class="dot"></span>
                    <span class="lab"><span class="php" aria-hidden="true">&lt;?</span>ENV</span>
                    <span class="line"></span>
                    <span class="num">03</span>
                </h3>
                <p class="sec-note">day-to-day runtime config.</p>
                <dl class="kv">
                    <dt>$ music</dt>
                    <dd>Spotify. <em>quiet enough to read over.</em></dd>
                    <dt>$ downtime</dt>
                    <dd>Netflix. <em>research, obviously.</em></dd>
                    <dt>$ fuel</dt>
                    <dd>cà phê sữa đá. <em>a constant, not a variable.</em></dd>
                    <dt>$ noise_level</dt>
                    <dd>low. <em>somewhere green and quiet, a book doing all the talking.</em></dd>
                </dl>
            </section>

            <p class="colophon"><span class="c" aria-hidden="true">#</span>nothing here is impressive; all of it is mine.</p>
            <p class="exit"><b>dao@chau</b>:~$ <span class="cmd"><a href="/">cd ~</a></span><span class="cur"
                                                                                                  aria-hidden="true"></span>
            </p>

        </div>
    </main>
</Layout>
