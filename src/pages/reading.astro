---
import Layout from "@/layouts/Layout.astro";
import LogoMark from "@/components/LogoMark.astro";
import RailFoot from "@/components/RailFoot.astro";
import { fetchShelf, type Book } from "@/utils/goodreads";
import { GOODREADS_USER_ID } from "@/data/config";

const [currentlyReading, favorites, recentlyRead] = await Promise.all([
    fetchShelf("currently-reading", 3),
    fetchShelf("favorites", 24),
    fetchShelf("read", 24),
]);

// merge read + favorites into one list so every favorite always shows up here,
// even if goodreads hasn't marked it "read" or it fell outside the read-shelf window
const shelfById = new Map<number, Book & { isFavorite: boolean }>();
for (const book of recentlyRead) shelfById.set(book.id, { ...book, isFavorite: false });
for (const book of favorites) {
    const existing = shelfById.get(book.id);
    if (existing) existing.isFavorite = true;
    else shelfById.set(book.id, { ...book, isFavorite: true });
}
const shelfBooks = [...shelfById.values()].sort((a, b) => {
    const at = (a.dateRead ?? a.dateAdded)?.getTime() ?? 0;
    const bt = (b.dateRead ?? b.dateAdded)?.getTime() ?? 0;
    return bt - at;
});

const profileUrl = GOODREADS_USER_ID
    ? `https://www.goodreads.com/user/show/${GOODREADS_USER_ID}`
    : null;

function isoDate(d: Date | null): string {
    return d ? d.toISOString().slice(0, 10) : "";
}
---

<Layout
        title="dao chau · reading"
        description="what's open right now, the rest pulled from the shelf."
>
    <main class="shell" data-screen-label="reading">

        <!-- identity rail -->
        <aside class="rail">
            <LogoMark />

            <div class="id-block">
                <h1 class="id-name"><a href="/"><span class="w">dao</span><span class="w">chau</span></a></h1>
                <p class="id-role">reading · the shelf</p>
            </div>

            <div class="rail-divider"></div>

            <nav aria-label="Sections">
                <ul class="nav">
                    <li><a href="/"><span class="n" aria-hidden="true">cd</span><span class="t">~ home</span></a></li>
                    <li><a href="#now"><span class="n" aria-hidden="true">01</span><span class="t">now</span></a></li>
                    <li><a href="#shelf"><span class="n" aria-hidden="true">02</span><span class="t">shelf</span></a></li>
                </ul>
            </nav>

            <RailFoot />
        </aside>

        <!-- content column -->
        <div class="content">

            <p class="prompt"><b>dao@chau</b>:~$ <span class="cmd" aria-hidden="true">dao --reading</span><span class="cur"
                                                                                          aria-hidden="true"></span></p>

            <h2 class="hero">off the clock, <em class="ln">mostly reading.</em></h2>
            <p class="hero-sub">what's open right now, the rest pulled from the shelf.</p>

            <!-- NOW READING -->
            <section id="now" aria-labelledby="s-now">
                <h3 class="sec" id="s-now">
                    <span class="dot"></span>
                    <span class="lab"><span class="php" aria-hidden="true">&lt;?</span>NOW</span>
                    <span class="line"></span>
                    <span class="num">01</span>
                </h3>

                {currentlyReading.length === 0 ? (
                        <p class="til-empty">nothing open right now. probably between books.</p>
                ) : (
                        <div class="now-list">
                            {currentlyReading.map((book) => (
                                    <a class="now-book" href={book.link} target="_blank" rel="noopener">
                                        <span class="now-cover">
                                            <img
                                                    src={book.coverUrl}
                                                    alt={`cover of ${book.title}`}
                                                    loading="lazy"
                                                    decoding="async"
                                                    width="96"
                                                    height="144"
                                            />
                                        </span>
                                        <span class="now-info">
                                            <span class="now-label">
                                                {book.dateAdded ? `started ${isoDate(book.dateAdded)}` : "in progress"}
                                            </span>
                                            <span class="now-title">{book.title}</span>
                                            <span class="now-author">by {book.author}</span>
                                            <span class="now-link"><span class="ic" aria-hidden="true">↗</span><span class="lbl">on goodreads</span></span>
                                        </span>
                                    </a>
                            ))}
                        </div>
                )}
            </section>

            <!-- SHELF -->
            <section id="shelf" aria-labelledby="s-shelf">
                <h3 class="sec" id="s-shelf">
                    <span class="dot"></span>
                    <span class="lab"><span class="php" aria-hidden="true">&lt;?</span>SHELF</span>
                    <span class="line"></span>
                    <span class="num">02 · {shelfBooks.length} books · {favorites.length} favorites</span>
                </h3>

                {shelfBooks.length === 0 ? (
                        <p class="til-empty">the shelf is empty here. check back after a rebuild.</p>
                ) : (
                        <div class="shelf-grid">
                            {shelfBooks.map((book) => (
                                    <a class="shelf-book" href={book.link} target="_blank" rel="noopener">
                                        <span class="shelf-cover">
                                            <img
                                                    src={book.coverUrl}
                                                    alt={`cover of ${book.title}`}
                                                    loading="lazy"
                                                    decoding="async"
                                                    width="96"
                                                    height="144"
                                            />
                                            {book.isFavorite && (
                                                    <span class="shelf-fav-mark" title="favorite" aria-label="favorite"></span>
                                            )}
                                        </span>
                                        <span class="shelf-title">{book.title}</span>
                                        <span class="shelf-author">{book.author}</span>
                                        {book.dateRead && (
                                                <time class="shelf-date" datetime={isoDate(book.dateRead)}>
                                                    {isoDate(book.dateRead)}
                                                </time>
                                        )}
                                    </a>
                            ))}
                        </div>
                )}
            </section>

            <p class="colophon"><span class="c" aria-hidden="true">#</span>pulled from goodreads on every rebuild{profileUrl && (
                    <> · <a href={profileUrl} target="_blank" rel="noopener" class="cmd coffee-link">full shelf ↗</a></>
            )}</p>
            <p class="exit"><b>dao@chau</b>:~$ <span class="cmd"><a href="/">cd ~</a></span><span class="cur"
                                                                                                  aria-hidden="true"></span>
            </p>

        </div>
    </main>
</Layout>
