---
import Layout from "@/layouts/Layout.astro";
import projects from "@/data/projects";
import LogoMark from "@/components/LogoMark.astro";
import RailFoot from "@/components/RailFoot.astro";
---

<Layout>
    <main class="shell" data-screen-label="home">

        <!-- identity rail -->
        <aside class="rail">
            <LogoMark />

            <div class="id-block">
                <h1 class="id-name"><span class="w">dao</span><span class="w">chau</span></h1>
                <p class="id-role">backend developer</p>
            </div>

            <div class="rail-divider"></div>

            <nav aria-label="Sections">
                <ul class="nav">
                    <li><a href="#desc"><span class="n">01</span><span class="t">description</span></a></li>
                    <li><a href="#projects"><span class="n">02</span><span class="t">echo</span></a></li>
                    <li><a href="#now"><span class="n">03</span><span class="t">now</span></a></li>
                    <li><a href="#notes"><span class="n">04</span><span class="t">notes</span></a></li>
                    <li><a href="/uses"><span class="n">05</span><span class="t">uses ↗</span></a></li>
                    <li><a href="/til"><span class="n">06</span><span class="t">til ↗</span></a></li>
                    <li><a href="/reading"><span class="n">07</span><span class="t">reading ↗</span></a></li>
                </ul>
            </nav>

            <RailFoot />
        </aside>

        <!-- content column -->
        <div class="content">

            <p class="prompt"><b>dao@chau</b>:~$ <span class="cmd">dao --help</span><span class="cur"
                                                                                          aria-hidden="true"></span></p>

            <h2 class="hero">behind the curtain, <em>keeping things running.</em></h2>
            <p class="hero-sub">writes the half of the web you never see.</p>

            <!-- DESCRIPTION -->
            <section id="desc" aria-labelledby="s-desc">
                <h3 class="sec" id="s-desc">
                    <span class="dot"></span>
                    <span class="lab"><span class="php">&lt;?</span>DESCRIPTION</span>
                    <span class="line"></span>
                    <span class="num">01</span>
                </h3>
                <div class="prose">
                    <p>I'm a PHP backend developer who's spent <em>a long while</em> in WordPress. I spend my days in
                        the backend at <em>ViiVue</em>, mostly WordPress work, from corporate sites to WooCommerce, with
                        the occasional Shopify job on the side.</p>
                    <p>off the clock I'm an introvert who reads more than is reasonable. I like fresh air, uncrowded
                        places, and slow days.</p>
                </div>
                <div class="chips chips-desc">
                    <span class="chip hl">--php</span>
                    <span class="chip">--wordpress</span>
                    <span class="chip">--woocommerce</span>
                    <span class="chip">--async</span>
                    <span class="chip">--people=few</span>
                    <span class="chip">--reading</span>
                </div>
            </section>

            <!-- ECHO / PROJECTS -->
            <section id="projects" aria-labelledby="s-proj">
                <h3 class="sec" id="s-proj">
                    <span class="dot"></span>
                    <span class="lab"><span class="php">&lt;?</span>ECHO</span>
                    <span class="line"></span>
                    <span class="num">02 · {projects.length} featured</span>
                </h3>
                <div class="projects">
                    {projects.map((project, i) => (
                            <a class="proj" href={project.link} target="_blank" rel="noopener">
                                <span class="idx">{String(i + 1).padStart(2, "0")}</span>
                                <span class="pname">{project.title}</span>
                                <span class="arrow">↗</span>
                                <span class="ptags">
                <span class="ptag" data-tag={project.platform}>{project.platform}</span>
                <span class="ptag role" data-tag={project.role}>{project.role}</span>
                <span class="ptag">{project.type}</span>
              </span>
                            </a>
                    ))}
                </div>
            </section>

            <!-- NOW -->
            <section id="now" aria-labelledby="s-now">
                <h3 class="sec" id="s-now">
                    <span class="dot"></span>
                    <span class="lab"><span class="php">&lt;?</span>NOW</span>
                    <span class="line"></span>
                    <span class="num">03 · june 2026</span>
                </h3>
                <dl class="kv">
                    <dt>$ work</dt>
                    <dd>in my element keeping the backend ticking at ViiVue, plus whatever needs fixing underneath.</dd>
                    <dt>$ learning</dt>
                    <dd>1% better is still better. no rush.</dd>
                    <dt>$ reading</dt>
                    <dd>always mid-book. <a href="/reading">full shelf ↗</a>.</dd>
                </dl>
            </section>

            <!-- NOTES -->
            <section id="notes" aria-labelledby="s-notes">
                <h3 class="sec" id="s-notes">
                    <span class="dot"></span>
                    <span class="lab"><span class="php">&lt;?</span>NOTES</span>
                    <span class="line"></span>
                    <span class="num">04</span>
                </h3>
                <ul class="notes">
                    <li><b>introvert by wiring</b>I recharge somewhere green and quiet, well away from a crowd.</li>
                    <li><b>bookaholic</b>the unread stack is a feature, not a bug.</li>
                    <li><b>minimalist by taste</b>I'd rather be calm and right than loud and sorry.</li>
                    <li><b>private, not secret</b>I stay dim online, on purpose. not hiding, just low-key. the light's
                        still on, though; email finds me best.
                    </li>
                </ul>
            </section>

            <!-- MANTRA -->
            <div class="mantra">
                <p class="mantra-prompt"><b>dao@chau</b>:~$ <span class="cmd">cat mantra</span></p>
                <p class="mantra-out"><span class="mantra-slash">/</span>You become what you feed your mind.<span class="mantra-slash">/</span></p>
            </div>

            <p class="colophon"><span class="c">#</span>this site is small on purpose, much like the rest of my life.
            </p>
<p class="exit"><b>dao@chau</b>:~$ <span class="cmd">exit 0</span><span class="cur"
                                                                                    aria-hidden="true"></span></p>

        </div>
    </main>
</Layout>
